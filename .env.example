# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=documents_db
POSTGRES_USER=documents_user
POSTGRES_PASSWORD=documents_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=True

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False
# Windows: use solo (default on win32). Linux/Docker: prefork
CELERY_WORKER_POOL=solo

# Set SYNC_PARSE=true to parse inline without Celery/Redis (recommended for local Windows dev)
SYNC_PARSE=true
